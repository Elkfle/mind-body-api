# Copiar este archivo como .env y completar los valores reales
# El archivo .env NUNCA se sube al repositorio (.gitignore lo excluye)

# Perfil activo: local | prod
SPRING_PROFILES_ACTIVE=local

# Base de datos (solo necesario si se cambian los defaults del compose.yaml)
DB_URL=jdbc:postgresql://localhost:55432/mindbody_db
DB_USERNAME=postgres
DB_PASSWORD=postgres

# JWT (cambiar en producción por una clave segura de 256+ bits)
JWT_SECRET=mindbody-local-secret-key-must-be-at-least-256-bits-long
JWT_EXPIRATION_MS=900000
JWT_REFRESH_EXPIRATION_DAYS=7

# Gemini AI (obtener en aistudio.google.com → Get API Key)
GEMINI_API_KEY=
GEMINI_MODEL=gemini-1.5-flash
